# ══════════════════════════════════════════════════════════════════════════
#  AI Notes Digitizer — Environment Variables
#  Copy this file to .env and fill in your values.
#  cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your-random-secret-key-here-change-this
HOST=0.0.0.0
PORT=5000
DEBUG=true

# ── Anthropic Claude API ─────────────────────────────────────────────────────
# Get your key: https://console.anthropic.com → API Keys
# Free tier: $5 credit on signup (~20,000 pages with Haiku model)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxx

# ── Claude Model Selection ───────────────────────────────────────────────────
# Fast & cheap:  claude-3-haiku-20240307        (~$0.00025 / 1K input tokens)
# Best quality:  claude-3-5-sonnet-20241022     (~$0.003   / 1K input tokens)
CLAUDE_MODEL=claude-3-haiku-20240307
CLAUDE_MAX_TOKENS=4096

# ── OCR Languages ────────────────────────────────────────────────────────────
# Comma-separated ISO 639-1 codes supported by EasyOCR
# Full list: https://www.jaided.ai/easyocr/
# Common: en (English), hi (Hindi), bn (Bengali), or (Odia/Oriya)
#         ta (Tamil), te (Telugu), fr (French), de (German), es (Spanish)
OCR_LANGUAGES=en,hi
OCR_GPU=false

# ── Tesseract binary ─────────────────────────────────────────────────────────
# Leave as 'tesseract' if it's in your PATH
# Windows example: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=tesseract

# ── Google Vision API (optional, for complex regional scripts) ───────────────
# Free: 1000 requests/month  https://cloud.google.com/vision
# Leave empty to skip
GOOGLE_VISION_API_KEY=

# ── File Storage ─────────────────────────────────────────────────────────────
UPLOADS_DIR=./uploads
OUTPUTS_DIR=./outputs
SESSIONS_DIR=./sessions
MAX_CONTENT_MB=50

# ── PDF Settings ─────────────────────────────────────────────────────────────
PDF_DPI=200
PDF_MAX_PAGES=100

# ── Session TTL ───────────────────────────────────────────────────────────────
SESSION_TTL_HOURS=24
